{
  "name": "openai",
  "description": "OpenAI API — GPT chat completions and text generation",
  "category": "ai",
  "modified_at": "2026-07-07T00:00:00Z",
  "source": "local_api",
  "kind": "service",
  "aliases": [
    "gpt",
    "chatgpt"
  ],
  "keywords": [
    "ai",
    "llm",
    "chat",
    "gpt",
    "openai",
    "generation"
  ],
  "base_url": "https://api.openai.com",
  "setup_steps": [
    "New to using OpenAI for AI? Here's how to do it..."
  ],
  "auth": {
    "type": "bearer",
    "setting": "api_key"
  },
  "headers": {
    "content-type": "application/json"
  },
  "usage": "invoke('openai', 'v1/chat/completions', { model: 'gpt-5.5', messages: [{ role: 'user', content: 'Hello' }], max_completion_tokens: 1024 })",
  "methods": [
    {
      "name": "v1/chat/completions",
      "description": "Send a chat completion request",
      "params": [
        "model",
        "messages",
        "max_completion_tokens"
      ]
    }
  ],
  "settings": {
    "api_key": {
      "type": "secret",
      "label": "API Key",
      "required": true
    }
  },
  "models_source": {
    "url": "https://api.openai.com/v1/models",
    "list_path": "data",
    "value_key": "id",
    "label_key": "id",
    "filter_prefixes": [
      "gpt-",
      "o3",
      "o4"
    ]
  },
  "models": {
    "quick": "gpt-5.4-mini",
    "standard": "gpt-5.5",
    "deep": "gpt-5.5"
  },
  "protocols": {
    "ai_chat": {
      "method": "v1/chat/completions",
      "max_output_tokens": 16384,
      "model_profiles": [
        {
          "prefix": "gpt-5",
          "max_output_tokens": 32768
        },
        {
          "prefix": "gpt-4o",
          "max_output_tokens": 16384
        }
      ],
      "features": [
        "tool_use",
        "streaming"
      ],
      "request": {
        "model_field": "model",
        "messages_field": "messages",
        "system_mode": "first_message",
        "max_tokens_field": "max_completion_tokens",
        "json_schema_field": "response_format",
        "json_schema_wrapper": {
          "type": "json_schema",
          "json_schema": {
            "name": "frame_files",
            "strict": false,
            "schema": "$schema"
          }
        },
        "extra": {
          "stream": false
        }
      },
      "response": {
        "text_path": "choices[0].message.content"
      },
      "tool_use": {
        "request_tools_field": "tools",
        "request_schema_key": "parameters",
        "assistant_tool_use_style": "tool_calls",
        "request_tool_wrapper": {
          "type": "function",
          "function": {
            "name": "$name",
            "description": "$description",
            "parameters": "$schema"
          }
        },
        "response_calls_path": "choices[0].message.tool_calls",
        "call_id_field": "id",
        "call_name_field": "function.name",
        "call_args_field": "function.arguments",
        "call_args_is_string": true,
        "result_role": "tool",
        "result_id_field": "tool_call_id"
      }
    }
  },
  "good_for": [
    "framegen",
    "modify",
    "chat",
    "text"
  ],
  "app_version_min": "0.2.0"
}
